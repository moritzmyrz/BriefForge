# ------------------------------------------------------------------
# BriefForge — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ------------------------------------------------------------------

# OpenAI API key (required for AI extraction)
OPENAI_API_KEY=sk-...

# Model to use for extraction (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: point to a different OpenAI-compatible base URL (e.g. Ollama, Groq)
# OPENAI_BASE_URL=https://api.openai.com/v1

# SQLite database file path (default: ./briefforge.db)
DATABASE_URL=./briefforge.db

# API server
PORT=3000
HOST=0.0.0.0

# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# Node environment
NODE_ENV=development
