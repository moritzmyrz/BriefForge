{
  "name": "briefforge",
  "version": "0.1.0",
  "description": "AI-native backend API for transforming unstructured text into structured, workflow-ready artifacts",
  "type": "module",
  "license": "MIT",
  "author": "moritzmyrz",
  "homepage": "https://github.com/moritzmyrz/briefforge#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/moritzmyrz/briefforge.git"
  },
  "bugs": {
    "url": "https://github.com/moritzmyrz/briefforge/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "extraction",
    "structured-output",
    "typescript",
    "fastify",
    "openai",
    "text-processing",
    "action-items",
    "workflow"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/app/index.js",
  "scripts": {
    "dev": "node --env-file=.env --watch --import tsx/esm src/app/index.ts",
    "build": "tsup",
    "start": "node dist/app/index.js",
    "extract": "node --env-file=.env --import tsx/esm cli/extract.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node --env-file=.env --import tsx/esm src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/sensible": "^5.6.0",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.36.4",
    "fastify": "^4.28.1",
    "openai": "^4.77.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "sigilid": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "drizzle-kit": "^0.28.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
